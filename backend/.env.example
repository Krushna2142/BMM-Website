PORT=5000
DATABASE_URL="postgresql://user:password@localhost:5432/cms_demo?schema=public"
JWT_SECRET="your_jwt_secret_here"
# JWT_EXPIRES_IN accepts string format like "1d" (1 day), "2h" (2 hours), "60s" (60 seconds)
# Or a number representing seconds (e.g., 86400 for 1 day)
JWT_EXPIRES_IN="1d"
BCRYPT_SALT_ROUNDS=12
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"
