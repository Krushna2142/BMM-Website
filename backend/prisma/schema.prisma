generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  ADMIN
  EDITOR
  VIEWER
}

enum PageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  PUBLISH
  UNPUBLISH
  RESTORE
  LOGIN
  LOGOUT
  UPLOAD
}

model AdminUser {
  id           String       @id @default(uuid())
  name         String
  email        String       @unique
  passwordHash String
  role         Role         @default(EDITOR)
  isActive     Boolean      @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  
  // Relations
  pageVersions  PageVersion[]
  sectionVersions SectionVersion[]
  auditLogs     AuditLog[]
}

model Page {
  id          String      @id @default(uuid())
  slug        String      @unique
  title       String
  description String?
  status      PageStatus  @default(DRAFT)
  
  // SEO
  seoTitle       String?
  seoDescription String?
  seoKeywords    String[]
  
  // Publishing
  publishedAt   DateTime?
  publishedBy   String?
  
  // Timestamps
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  
  // Soft delete
  deletedAt     DateTime?
  
  // Relations
  sections      Section[]
  versions      PageVersion[]
}

model PageVersion {
  id            String      @id @default(uuid())
  pageId        String
  versionNumber Int
  status        PageStatus
  
  // Snapshot
  title         String
  description   String?
  seoTitle      String?
  seoDescription String?
  
  // Metadata
  changeSummary String?
  createdBy     String
  createdAt     DateTime    @default(now())
  
  // Relations
  page          Page        @relation(fields: [pageId], references: [id], onDelete: Cascade)
  author        AdminUser   @relation(fields: [createdBy], references: [id])
  
  @@unique([pageId, versionNumber])
}

model Section {
  id          String    @id @default(uuid())
  pageId      String
  type        String    // hero, stats, action_buttons, sponsors, image_slider, committee, executive_members, trustees, content, about, cta, features
  label       String?   // Admin-friendly label for identifying sections
  order       Int
  isVisible   Boolean   @default(true)
  props       Json      // Flexible JSON for any section type
  
  // Responsive variants
  mobileProps Json?
  
  // Custom styling
  customStyles Json?
  
  // Scheduling
  publishStartAt DateTime?
  publishEndAt   DateTime?
  
  // Timestamps
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  createdBy   String?
  updatedBy   String?
  
  // Soft delete
  deletedAt   DateTime?
  
  // Version tracking
  versionNumber Int     @default(1)
  
  // Relations
  page        Page      @relation(fields: [pageId], references: [id], onDelete: Cascade)
  media       Media[]
  versions    SectionVersion[]
}

model SectionVersion {
  id            String    @id @default(uuid())
  sectionId     String
  versionNumber Int
  isVisible     Boolean
  order         Int
  props         Json
  label         String?
  
  // Metadata
  changeSummary String?
  createdBy     String
  createdAt     DateTime  @default(now())
  
  // Relations
  section       Section   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  author        AdminUser @relation(fields: [createdBy], references: [id])
  
  @@unique([sectionId, versionNumber])
}

model SectionTemplate {
  id            String    @id @default(uuid())
  name          String
  sectionType   String
  description   String?
  defaultProps  Json      @default("{}")
  thumbnailUrl  String?
  isSystem      Boolean   @default(false)
  category      String?   // e.g., "hero", "content", "media"
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Media {
  id          String    @id @default(uuid())
  sectionId   String?
  filename    String
  originalName String?
  url         String
  mimeType    String
  size        Int
  width       Int?
  height      Int?
  altText     String?
  title       String?
  folder      String    @default("/")
  
  // Timestamps
  createdAt   DateTime  @default(now())
  uploadedBy  String?
  
  // Relations
  section     Section?  @relation(fields: [sectionId], references: [id], onDelete: SetNull)
}

model AuditLog {
  id          String       @id @default(uuid())
  
  // Who
  userId      String?
  userEmail   String?
  
  // What
  action      AuditAction
  entityType  String       // "page", "section", "media", "user"
  entityId    String?
  entityLabel String?
  
  // Details
  oldValues   Json?
  newValues   Json?
  changeSummary String?
  ipAddress   String?
  userAgent   String?
  
  // When
  createdAt   DateTime     @default(now())
  
  // Relations
  user        AdminUser?   @relation(fields: [userId], references: [id], onDelete: SetNull)
  
  @@index([entityType, entityId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}
