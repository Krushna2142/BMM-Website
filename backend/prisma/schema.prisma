generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  SUPER_ADMIN
  EDITOR
}

enum PageStatus {
  DRAFT
  PUBLISHED
}

model AdminUser {
  id           String   @id @default(uuid())
  name         String
  email        String   @unique
  passwordHash String
  role         Role     @default(EDITOR)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Page {
  id        String      @id @default(uuid())
  slug      String      @unique
  title     String
  status    PageStatus  @default(DRAFT)
  sections  Section[]
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

model Section {
  id        String   @id @default(uuid())
  pageId    String
  type      String   // hero, stats, action_buttons, sponsors, image_slider, committee, executive_members, trustees
  order     Int
  isVisible Boolean  @default(true)
  props     Json     // Flexible JSON for any section type
  page      Page     @relation(fields: [pageId], references: [id], onDelete: Cascade)
  media     Media[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Media {
  id        String   @id @default(uuid())
  sectionId String?
  filename  String
  url       String
  mimeType  String
  size      Int
  section   Section? @relation(fields: [sectionId], references: [id], onDelete: SetNull)
  createdAt DateTime @default(now())
}